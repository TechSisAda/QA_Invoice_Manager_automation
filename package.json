{
  "name": "qa-invoice-manager-automation",
  "version": "1.0.0",
  "description": "WebdriverIO test automation suite for InvoiceManager — smoke, regression, and e2e tests",
  "type": "module",
  "scripts": {
    "test:smoke":       "wdio wdio.conf.js --spec test/specs/smoke",
    "test:regression":  "wdio wdio.conf.js --spec test/specs/regression",
    "test:e2e":         "wdio wdio.conf.js --spec test/specs/e2e",
    "test:all":         "wdio wdio.conf.js",
    "report:generate":  "allure generate allure-results --clean -o allure-report",
    "report:open":      "allure open allure-report",
    "agent:run":        "node agent/test-runner-agent.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "chromedriver": "latest",
    "@wdio/chromedriver-service": "^9.0.0",
    "allure-commandline": "^2.29.0",
    "dotenv": "^16.0.0"
  }
}
