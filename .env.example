# Copy this file to .env and fill in your values

# Main app base URL
BASE_URL=https://invoicemanager.ng

# Compliance / TIN subdomain
COMPLIANCE_URL=https://compliance.invoicemanager.ng

# Business instance URL (subdomain created after subscription)
INSTANCE_URL=https://benten.invoicemanager.ng

# Run browser visibly while mapping selectors (set to true in CI)
HEADLESS=false

# Test account credentials (for the benten instance login)
TEST_EMAIL=benten@mail.com
TEST_PASS=password
TEST_FIRST_NAME=QA
TEST_LAST_NAME=Automation
TEST_PHONE=08112333255

# AI Agent (only needed for: node agent/test-runner-agent.js)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
