# Copy this file to .env and fill in your values

# Main app base URL
BASE_URL=https://invoicemanager.ng

# Compliance / TIN subdomain
COMPLIANCE_URL=https://compliance.invoicemanager.ng

# Run browser visibly while mapping selectors (set to true in CI)
HEADLESS=false

# Test account credentials
TEST_EMAIL=your-test-account@email.com
TEST_PASS=your-password

# AI Agent (only needed for: node agent/test-runner-agent.js)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
